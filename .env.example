# Admin login configuration
ADMIN_PASSWORD=your_admin_password_here
ADMIN_SESSION_TOKEN=your_admin_session_token_here

# Supabase (REQUIRED)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Cloudflare R2 Storage (for gallery photos)
R2_ACCOUNT_ID=your_r2_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=metmal-gallery
R2_PUBLIC_URL=https://pub-xxx.r2.dev

# Google Apps Script (legacy - only needed for letter request)
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
ADMIN_API_TOKEN=your_admin_api_token_here
